# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
*.egg

# Virtual environment
.venv/
venv/

# Environment variables — 密钥文件
.env
.env.*

# Large data — 另行下载/生成
dataset_building/data/
dataset_building/processed/
dataset_building/external_data/
dataset_building/release/

# Checkpoints & model weights
*.ckpt
*.pth
*.pt2

# NATS JetStream 运行时存储
jetstream_storage/

# 生成的分析图片
dataset_building/analysis/
dataset_building/checkpoints/*.png
dataset_building/checkpoints/*.png

# 缓存文件
*.cache
dataset_building/pipeline/uniprot_ec_cache.json

# 旧版模型归档（保留目录说明，不跟踪代码）
dataset_building/models_v1_obsolete/

# Runtime artifacts
*.log
*.tar.gz
tmp/

# Shell scripts 运行产物
*.sh
!dataset_building/scripts/*.sh
!scripts/**/*.sh

# Gold data 软链接/二进制
dataset_building/golddata/ligands
dataset_building/golddata/proteins.h5

# Raw data — track nothing under these
dataset_building/turnup/
dataset_building/uniprotprot/
dataset_building/BRENDA/
dataset_building/BindingDB/
dataset_building/OED/
dataset_building/SABIO-RK/
dataset_building/SKiD/
dataset_building/KEGG/

# Old model archives with checkpoints (>25MB)
dataset_building/models_v1_obsolete/checkpoints/
dataset_building/models_v1_obsolete/*.ckpt
